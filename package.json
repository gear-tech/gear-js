{
  "name": "gear-js",
  "private": true,
  "author": "Gear Technologies",
  "license": "GPL-3.0",
  "repository": "git@github.com:gear-tech/gear-js.git",
  "engines": {
    "node": ">=20"
  },
  "bugs": {
    "url": "https://github.com/gear-tech/gear-js/issues"
  },
  "homepage": "https://github.com/gear-tech/gear-js",
  "keywords": [
    "gear",
    "gear-js"
  ],
  "packageManager": "pnpm@11.9.0",
  "version": "1.0.0",
  "workspaces": [
    "apis/gear",
    "apis/vara-eth",
    "idea/gear/common",
    "idea/gear/explorer",
    "idea/gear/faucet",
    "idea/gear/frontend",
    "idea/gear/indexer-db",
    "idea/gear/meta-storage",
    "idea/gear/squid",
    "idea/vara-eth/explorer",
    "idea/vara-eth/frontend",
    "idea/vara-eth/indexer",
    "idea/vara-eth/upload-code-service",
    "idea/vara-eth/indexer-db",
    "tools/cli",
    "tools/txwrapper",
    "utils/frontend-configs",
    "utils/gear-hooks",
    "utils/gear-ui",
    "utils/logger",
    "utils/util",
    "utils/vara-ui",
    "utils/wallet-connect",
    "utils/sails-payload-form"
  ],
  "scripts": {
    "clean": "pnpm -r --parallel run clean && pnpm -r exec -- rm -rf node_modules && rm -rf node_modules",
    "clean:deps-only": "pnpm -r exec -- rm -rf node_modules && rm -rf node_modules",
    "build": "pnpm -r run build",
    "build:gear-api": "pnpm --filter @gear-js/api build",
    "build:vara-eth-api": "pnpm --filter @vara-eth/api build",
    "build:gear-js-util": "pnpm --filter gear-js-util build",
    "build:gear-idea-common": "pnpm --filter @gear-js/api --filter gear-idea-common build",
    "build:gear-idea-explorer": "pnpm --filter @gear-js/api --filter gear-idea-common --filter gear-idea-explorer --filter gear-idea-indexer-db build",
    "build:gear-idea-faucet": "pnpm --filter @gear-js/api --filter gear-idea-faucet --filter gear-idea-common build",
    "build:gear-idea-meta-storage": "pnpm --filter @gear-js/api --filter gear-idea-meta-storage --filter gear-idea-common build",
    "build:gear-idea-squid": "pnpm --filter @gear-js/api --filter gear-idea-common --filter gear-idea-indexer-db --filter gear-idea-squid build",
    "build:gear-idea-backend": "pnpm --filter @gear-js/api --filter gear-idea-common --filter gear-idea-explorer --filter gear-idea-faucet --filter gear-idea-indexer-db --filter gear-idea-meta-storage --filter gear-idea-squid build",
    "build:gear-idea-frontend": "pnpm --filter gear-idea-frontend --filter @gear-js/frontend-configs --filter @gear-js/ui --filter @gear-js/vara-ui --filter @gear-js/react-hooks --filter @gear-js/wallet-connect --filter @gear-js/api build",
    "build:gear-idea": "pnpm --filter gear-idea-frontend --filter @gear-js/frontend-configs --filter @gear-js/ui --filter @gear-js/vara-ui --filter @gear-js/react-hooks --filter @gear-js/wallet-connect --filter @gear-js/api build",
    "build:varaeth-idea-frontend": "pnpm --filter varaeth-idea-frontend --filter @gear-js/frontend-configs --filter @gear-js/api --filter @vara-eth/api --filter @gear-js/sails-payload-form build",
    "build:varaeth-idea-upload-code": "pnpm --filter @vara-eth/idea-upload-code build",
    "build:varaeth-idea-indexer-db": "pnpm --filter @vara-eth/idea-indexer-db build",
    "build:varaeth-idea-indexer": "pnpm --filter @vara-eth/idea-indexer-db --filter @vara-eth/idea-indexer build",
    "build:varaeth-idea-explorer": "pnpm --filter @vara-eth/idea-indexer-db --filter @vara-eth/idea-explorer build",
    "build:ui": "pnpm --filter @gear-js/ui --filter @gear-js/frontend-configs build",
    "build:sails-payload-form": "pnpm --filter @gear-js/sails-payload-form build",
    "build:vara-ui": "pnpm --filter @gear-js/vara-ui --filter @gear-js/frontend-configs build",
    "build:hooks": "pnpm --filter @gear-js/react-hooks --filter @gear-js/frontend-configs --filter @gear-js/api build",
    "build:wallet-connect": "pnpm --filter @gear-js/wallet-connect --filter @gear-js/frontend-configs --filter @gear-js/react-hooks --filter @gear-js/ui --filter @gear-js/vara-ui build",
    "build:utils": "pnpm --filter @gear-js/frontend-configs --filter @gear-js/ui --filter @gear-js/vara-ui --filter @gear-js/react-hooks --filter @gear-js/wallet-connect build",
    "build:txwrapper": "pnpm --filter @gear-js/txwrapper build",
    "build:cli": "pnpm --filter @gear-js/cli build",
    "build:tools": "pnpm --filter @gear-js/api --filter @gear-js/cli --filter @gear-js/txwrapper build",
    "build:frontend-configs": "pnpm --filter @gear-js/frontend-configs build",
    "test:gear-api": "pnpm --filter @gear-js/api test",
    "test:vara-eth-api": "pnpm --filter @vara-eth/api test",
    "test:gear-js-util": "pnpm --filter gear-js-util test",
    "test:gear-idea-backend": "pnpm --parallel --filter gear-idea-meta-storage --filter gear-idea-faucet run test",
    "test:gear-idea-meta-storage": "pnpm --filter gear-idea-meta-storage test",
    "test:gear-idea-faucet": "pnpm --filter gear-idea-faucet test",
    "test:gear-idea-explorer": "pnpm --filter gear-idea-explorer test",
    "test:varaeth-idea-explorer": "pnpm --filter @vara-eth/idea-explorer test",
    "test:txwrapper": "pnpm --filter @gear-js/txwrapper test",
    "test:ui": "pnpm --filter @gear-js/ui test",
    "test": "pnpm -r --parallel run test",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:apis": "biome check apis",
    "check:idea": "biome check idea",
    "bump:polkadot": "node scripts/update-deps.mjs polkadot && pnpm install",
    "bump:gear-api": "node scripts/update-deps.mjs gear-api",
    "bump:gear-idea": "node scripts/update-gear-idea-version.mjs",
    "check:gear-idea-version": "node scripts/check-gear-idea-version.mjs"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-typescript": "^7.28.5",
    "@biomejs/biome": "^2.4.15",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@swc/core": "^1.15.24",
    "@types/babel__core": "^7.20.5",
    "@types/babel__preset-env": "^7.10.0",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "4.4.12",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "rollup": "^4.60.2",
    "rollup-plugin-typescript2": "^0.37.0",
    "sass": "^1.83.4",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.0.12",
    "vitest": "^4.1.4"
  }
}
