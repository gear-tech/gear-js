{
  "compilerOptions": {
    "lib": ["es5", "es6", "es7", "esnext", "dom"],
    "target": "esnext",
    "module": "ESNext",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "strictPropertyInitialization": false,
    "rootDir": "./src",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "pretty": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "strict": false,
    "paths": {
      "@polkadot/api/augment": ["./src/types/augment/augment-api.ts"],
    },
  },
  "include": ["./src"],
}
