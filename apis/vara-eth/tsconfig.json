{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "rootDir": "./src",
    "outDir": "./lib",
    "allowJs": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "types": ["jest", "node"],
    "paths": {
      "sails-js": ["./node_modules/sails-js/lib/index.d.ts"],
      "sails-js/*": ["./node_modules/sails-js/lib/*.d.ts"]
    }
  },
  "exclude": ["node_modules", "lib"]
}
