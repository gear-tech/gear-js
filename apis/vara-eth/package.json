{
  "name": "@vara-eth/api",
  "version": "0.3.2",
  "description": "Typescript library for interacting with Vara.Eth network",
  "repository": {
    "type": "git",
    "url": "https://github.com/gear-tech/gear-js"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "npx jest --runInBand",
    "test:only": "yarn node --no-warnings --experimental-vm-modules $(../../node_modules/.bin/jest) --runInBand",
    "test:no-setup": "npx jest",
    "build": "npx rollup -c",
    "clean": "rm -rf lib",
    "abi": "node scripts/convert-abi.mjs",
    "pack": "mkdir -p ../../artifacts && yarn pack --out ../../artifacts/vara-eth-api.tgz"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./abi": {
      "types": "./lib/eth/abi/index.d.ts",
      "import": "./lib/eth/abi/index.js",
      "require": "./lib/eth/abi/index.cjs"
    },
    "./signer": {
      "types": "./lib/signer/index.d.ts",
      "import": "./lib/signer/index.js",
      "require": "./lib/signer/index.cjs"
    },
    "./eth/contracts": {
      "types": "./lib/eth/contracts/index.d.ts",
      "import": "./lib/eth/contracts/index.js",
      "require": "./lib/eth/contracts/index.cjs"
    },
    "./eth/router": {
      "types": "./lib/eth/contracts/router.contract.d.ts",
      "import": "./lib/eth/contracts/router.contract.js",
      "require": "./lib/eth/contracts/router.contract.cjs"
    }
  },
  "peerDependencies": {
    "kzg-wasm": "1.0.0",
    "viem": "*"
  },
  "devDependencies": {
    "@types/ws": "8.18.1",
    "kzg-wasm": "1.0.0",
    "viem": "npm:@vara-eth/viem@2.47.7-1",
    "ws": "8.18.3"
  },
  "files": [
    "lib"
  ],
  "dependencies": {
    "@noble/hashes": "1.8.0"
  }
}
