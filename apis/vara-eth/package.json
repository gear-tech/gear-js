{
  "name": "@vara-eth/api",
  "version": "0.6.0-rc.0",
  "description": "Typescript library for interacting with Vara.Eth network",
  "repository": {
    "type": "git",
    "url": "https://github.com/gear-tech/gear-js"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "npx vitest run",
    "test:only": "npx vitest run",
    "test:unit": "npx vitest run --config vitest.unit.config.ts",
    "build": "npx rollup -c",
    "clean": "rm -rf lib",
    "abi": "node scripts/convert-abi.mjs",
    "poc:ethexe": "npx tsx scripts/poc-wallet.ts",
    "typecheck:poc": "npx tsc --project scripts/tsconfig.poc.json",
    "pack": "mkdir -p ../../artifacts && yarn pack --out ../../artifacts/vara-eth-api.tgz"
  },
  "main": "./lib/cjs/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./abi": {
      "types": "./lib/eth/abi/index.d.ts",
      "import": "./lib/eth/abi/index.js",
      "require": "./lib/cjs/eth/abi/index.js"
    },
    "./signer": {
      "types": "./lib/signer/index.d.ts",
      "import": "./lib/signer/index.js",
      "require": "./lib/cjs/signer/index.js"
    },
    "./eth/contracts": {
      "types": "./lib/eth/contracts/index.d.ts",
      "import": "./lib/eth/contracts/index.js",
      "require": "./lib/cjs/eth/contracts/index.js"
    },
    "./eth/router": {
      "types": "./lib/eth/contracts/router.contract.d.ts",
      "import": "./lib/eth/contracts/router.contract.js",
      "require": "./lib/cjs/eth/contracts/router.contract.js"
    },
    "./util": {
      "types": "./lib/util/index.d.ts",
      "import": "./lib/util/index.js",
      "require": "./lib/cjs/util/index.js"
    }
  },
  "peerDependencies": {
    "kzg-wasm": "1.0.0",
    "viem": "*"
  },
  "devDependencies": {
    "@gear-js/api": "workspace:*",
    "@polkadot/api": "^16.5.1",
    "@types/ws": "8.18.1",
    "kzg-wasm": "1.0.0",
    "sails-js": "^1.0.0",
    "viem": "npm:@vara-eth/viem@2.48.11",
    "ws": "8.21.0"
  },
  "files": [
    "lib"
  ],
  "dependencies": {
    "@noble/hashes": "2.2.0"
  }
}
