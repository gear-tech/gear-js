{
  "name": "@vara-eth/idea-indexer-db",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "lib/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./lib/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf lib && npx tsc",
    "migration:generate": "yarn build && npx typeorm migration:generate -d lib/dataSource.js -o db/migrations/$NAME",
    "migration:apply": "npx typeorm migration:run -d lib/dataSource.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pg": "8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "0.3.29"
  }
}
