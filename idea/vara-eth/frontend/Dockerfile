FROM node:20-bookworm AS builder

WORKDIR /src

RUN corepack enable

COPY . .

RUN pnpm install --frozen-lockfile

RUN pnpm add -D -w storybook@8

ARG VITE_WALLET_CONNECT_PROJECT_ID \
    VITE_VARA_ETH_NODE_ADDRESSES_TESTNET \
    VITE_VARA_ETH_NODE_ADDRESSES_MAINNET \
    VITE_ETH_NODE_ADDRESS_TESTNET \
    VITE_ETH_NODE_ADDRESS_MAINNET \
    VITE_ETH_CHAIN_ID_TESTNET \
    VITE_ETH_CHAIN_ID_MAINNET \
    VITE_EXPLORER_URL_TESTNET \
    VITE_EXPLORER_URL_MAINNET \
    VITE_ROUTER_CONTRACT_ADDRESS_TESTNET \
    VITE_ROUTER_CONTRACT_ADDRESS_MAINNET \
    VITE_METADATA_STORAGE_API_URL \
    VITE_CODE_VALIDATION_SERVICE_URL \
    VITE_ETHERSCAN_URL_TESTNET \
    VITE_ETHERSCAN_URL_MAINNET

ENV VITE_WALLET_CONNECT_PROJECT_ID=${VITE_WALLET_CONNECT_PROJECT_ID} \
    VITE_VARA_ETH_NODE_ADDRESSES_TESTNET=${VITE_VARA_ETH_NODE_ADDRESSES_TESTNET} \
    VITE_VARA_ETH_NODE_ADDRESSES_MAINNET=${VITE_VARA_ETH_NODE_ADDRESSES_MAINNET} \
    VITE_ETH_NODE_ADDRESS_TESTNET=${VITE_ETH_NODE_ADDRESS_TESTNET} \
    VITE_ETH_NODE_ADDRESS_MAINNET=${VITE_ETH_NODE_ADDRESS_MAINNET} \
    VITE_ETH_CHAIN_ID_TESTNET=${VITE_ETH_CHAIN_ID_TESTNET} \
    VITE_ETH_CHAIN_ID_MAINNET=${VITE_ETH_CHAIN_ID_MAINNET} \
    VITE_EXPLORER_URL_TESTNET=${VITE_EXPLORER_URL_TESTNET} \
    VITE_EXPLORER_URL_MAINNET=${VITE_EXPLORER_URL_MAINNET} \
    VITE_ROUTER_CONTRACT_ADDRESS_TESTNET=${VITE_ROUTER_CONTRACT_ADDRESS_TESTNET} \
    VITE_ROUTER_CONTRACT_ADDRESS_MAINNET=${VITE_ROUTER_CONTRACT_ADDRESS_MAINNET} \
    VITE_METADATA_STORAGE_API_URL=${VITE_METADATA_STORAGE_API_URL} \
    VITE_CODE_VALIDATION_SERVICE_URL=${VITE_CODE_VALIDATION_SERVICE_URL} \
    VITE_ETHERSCAN_URL_TESTNET=${VITE_ETHERSCAN_URL_TESTNET} \
    VITE_ETHERSCAN_URL_MAINNET=${VITE_ETHERSCAN_URL_MAINNET} \
    DISABLE_ESLINT_PLUGIN=true \
    ESLINT_NO_DEV_ERRORS=true

RUN pnpm run build:varaeth-idea-frontend

FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production

RUN npm install -g serve@14

COPY --from=builder --chown=node:node /src/idea/vara-eth/frontend/dist ./dist

USER node

EXPOSE 3000

CMD ["serve", "-s", "dist", "-l", "3000"]
